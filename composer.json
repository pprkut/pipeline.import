{
    "name": "pipeline-etl/import",
    "description": "Pipeline.Import is a module for loading data into a system",
    "keywords": [
        "pipeline-etl",
        "data import",
        "ETL"
    ],
    "homepage": "https://github.com/pipeline-etl/pipeline.import",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "optimize-autoloader": true
    },
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "framna-nl/php-library-justfiles": "dev-master",
        "lunr/coding-standard": "0.12.0",
        "phpstan/phpstan": "~2.1.36",
        "phpunit/phpunit": ">=10.5 <11.0",
        "squizlabs/php_codesniffer": ">=4.0",
        "shipmonk/composer-dependency-analyser": "~1.8"
    },
    "scripts": {
        "phpcs": [
            "just phpcs"
        ],
        "phpstan": [
            "just phpstan"
        ],
        "phpunit": [
            "just phpunit"
        ]
    },
    "autoload": {
        "psr-4": {
            "Pipeline\\": "src/Pipeline/"
        }
    }
}
